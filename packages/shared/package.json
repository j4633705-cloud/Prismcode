{
  "name": "@prismcode543/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:js": "bun build ./src/index.ts --outdir ./dist --target node --format esm --external zod --external ai",
    "build:types": "tsc --emitDeclarationOnly --project tsconfig.json",
    "build": "bun run build:js && bun run build:types",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "ai": "^6.0.184",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

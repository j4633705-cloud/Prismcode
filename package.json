{
  "name": "prismcode",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "bun run scripts/postinstall.js",
    "dev:cli": "bun run --watch packages/cli/src/index.tsx",
    "dev:server": "powershell -ExecutionPolicy Bypass -File scripts/kill-port-3001.ps1; bun run packages/server/src/index.ts",
    "dev:server:hot": "bun run --hot packages/server/src/index.ts",
    "build": "bun run --filter '@prismcode543/*' build",
    "build:cli": "bun run --filter @prismcode543/cli build",
    "build:binary": "bun build --compile --target=bun-windows-x64-modern --outfile=dist/prismcode ./packages/cli/src/index.tsx",
    "link:cli": "bun run build:cli && cd packages/cli && bun link",
    "test": "bun run --filter '@prismcode543/*' test",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "lint": "eslint packages/",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.32.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j4633705-cloud/Prismcode.git"
  },
  "bugs": {
    "url": "https://github.com/j4633705-cloud/Prismcode/issues"
  },
  "homepage": "https://github.com/j4633705-cloud/Prismcode#readme"
}

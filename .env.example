## Required — defaults to http://localhost:3001
API_URL=http://localhost:3001
PRISMCODE_API_URL=http://localhost:3001

## Database — SQLite (file:) for local dev, PostgreSQL for production
DATABASE_URL=file:./prisma/prismcode.db

## AI Providers (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENCODE_API_KEY=

## Clerk OAuth — required for authentication
CLERK_FRONTEND_DOMAIN=
CLERK_OAUTH_CLIENT_ID=
CLERK_OAUTH_CLIENT_SECRET=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

## Polar.sh Billing (optional)
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_CREDITS_METER_ID=
POLAR_FREE_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=

## Cloud deployment overrides
# FRONTEND_URL=https://prismcode.dev
# DATABASE_URL=postgresql://user:password@host:5432/prismcode
# PORT=3001
